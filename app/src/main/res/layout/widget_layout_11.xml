<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/img_11"
    android:layout_width="match_parent"
    android:paddingBottom="15dp"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/timeText"
        android:text="19"
        android:textSize="55sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:textColor="@color/widgets_brown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/islamicDate"
        android:text="Ramadan 1447"
        android:textSize="22sp"
        android:textColor="@color/widgets_accent_yellow"
        android:layout_marginTop="8dp"
        android:fontFamily="serif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/gregorianDate"
        android:text="Fri, Mar 14"
        android:textSize="25sp"
        android:fontFamily="serif"
        android:textColor="@color/widgets_accent_yellow"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>